    {
      "parameters": {
        "jsCode": "const p = $('Parsear Mensagem').item.json;\nlet moradores = [], sessoes = [];\ntry { const t = $('GET Morador').item.json.data ?? $('GET Morador').item.json; moradores = typeof t === 'string' ? JSON.parse(t) : (Array.isArray(t) ? t : []); } catch(e) { moradores = []; }\ntry { const t = $('GET Sessao').item.json.data  ?? $('GET Sessao').item.json;  sessoes   = typeof t === 'string' ? JSON.parse(t) : (Array.isArray(t) ? t : []); } catch(e) { sessoes   = []; }\nconst m = moradores[0] ?? null;\nconst s = sessoes[0]   ?? null;\nreturn [{ json: {\n  from:              p.from,\n  texto:             p.texto,\n  buttonId:          p.buttonId,\n  instance:          p.instance,\n  moradorEncontrado: m !== null,\n  moradorId:         m?.id          ?? null,\n  moradorNome:       m?.nome        ?? null,\n  moradorApto:       m?.apartamento ?? null,\n  moradorBloco:      m?.bloco       ?? null,\n  sessaoEtapa:       s?.etapa       ?? null,\n  sessaoDados:       s?.dados       ?? {}\n} }];"
      },
