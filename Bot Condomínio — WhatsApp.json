      "parameters": {
        "jsCode": "const d = $json;\nconst t = (d.texto ?? '').trim();\nconst b = d.buttonId;\n\nlet rota = 'menu';\nif      (b === 'btn_encomendas'  || t === '1') rota = 'encomendas';\nelse if (b === 'btn_visitantes'  || t === '2') rota = 'visitantes';\nelse if (b === 'btn_ocorrencias' || t === '3') rota = 'ocorrencias';\nelse if (t.toUpperCase().startsWith('RETIREI'))  rota = 'retirada';\n\nreturn [{ json: { ...d, rota } }];"
