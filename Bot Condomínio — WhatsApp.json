    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.data ?? $input.first().json;\nlet lista = [];\ntry { lista = typeof raw === 'string' ? JSON.parse(raw) : (Array.isArray(raw) ? raw : []); } catch(e) { lista = []; }\nconst ctx = $('Roteador').item.json;\nconst from = ctx.from, instance = ctx.instance, nome = ctx.moradorNome;\nif (lista.length === 0) {\n  return [{ json: { from, instance, msg: `📭 *Sem encomendas*\\n\\nOlá, ${nome}! Não há encomendas aguardando retirada.\\n\\nAssim que chegar algo, avisamos! 😊` } }];\n}\nlet t = `📦 *Suas Encomendas* (${lista.length})\\n\\n`;\nlista.forEach((e, i) => {\n  const dt = e.data_recebimento ? new Date(e.data_recebimento).toLocaleString('pt-BR', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '?';\n  t += `*${i+1}. ${e.descricao}*\\n   📅 ${dt}\\n\\n`;\n});\nt += `_Retire na portaria com documento. 🏢_\\n\\nPara confirmar retirada envie: *RETIREI 1*`;\nreturn [{ json: { from, instance, msg: t } }];"
      },
