        2048,
        5536
      ]
    },
    {
      "parameters": {
        "jsCode": "const d = $json;\nconst etapa = d.sessaoEtapa, texto = d.texto ?? '', dados = d.sessaoDados ?? {};\nlet nd = { ...dados }, prox = null, resp = '', ok = false;\n\nif (!etapa) {\n  resp = 'Olá! 👋 Não encontrei seu cadastro.\\n\\nVamos fazer seu registro rapidinho! 😊\\n\\nQual é o seu *nome completo*?';\n  prox = 'aguardando_nome'; nd = {};\n} else if (etapa === 'aguardando_nome') {\n  if (texto.length < 3) { resp = '⚠️ Nome muito curto. Digite seu nome completo.'; prox = 'aguardando_nome'; }\n  else { nd.nome = texto; resp = `Ótimo, *${texto}*! 🏠\\n\\nQual é o número do seu *apartamento*?`; prox = 'aguardando_apto'; }\n} else if (etapa === 'aguardando_apto') {\n  if (texto.length < 1) { resp = '⚠️ Informe o número do apartamento.'; prox = 'aguardando_apto'; }\n  else { nd.apto = texto; resp = `Perfeito! 🏢\\n\\nQual é o *bloco*?\\n_(Ex: A, B — ou \"Único\" se não houver)_`; prox = 'aguardando_bloco'; }\n} else if (etapa === 'aguardando_bloco') {\n  nd.bloco = texto; ok = true;\n  resp = `✅ *Cadastro realizado!*\\n\\n👤 ${nd.nome}\\n🏠 Ap. ${nd.apto} - Bloco ${nd.bloco}\\n\\nBem-vindo(a)! 🎉\\n\\nEnvie qualquer mensagem para o menu.`;\n}\n\nreturn [{ json: { from: d.from, instance: d.instance, resp, prox, nd: JSON.stringify(nd), ok, nome: nd.nome ?? '', apto: nd.apto ?? '', bloco: nd.bloco ?? '' } }];"
      },
